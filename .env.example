# ── Yahoo Fantasy API ──────────────────────────────────────────────
# 聯盟 ID，兩種格式皆可：
#   完整格式（推薦）：{game_key}.l.{league_number}，例如 423.l.230329
#   僅數字：230329（程式會自動補上當前賽季 game_key）
# 聯盟首頁 URL 可找到 league_number，game_key 可在 Yahoo Fantasy 開發者頁確認
YAHOO_LEAGUE_ID=your_league_id_here

# 執行 python local_auth.py 後取得的完整 JSON，貼成一行
YAHOO_OAUTH_JSON={"consumer_key":"your_key","consumer_secret":"your_secret","access_token":"...","refresh_token":"...","token_type":"bearer","guid":"...","token_time":1700000000.0,"expires_in":3600}

# 運動類型（mlb / nfl / nba / nhl）
YAHOO_SPORT=mlb

# ── Resend 寄信（https://resend.com） ───────────────────────────────
# 1. 註冊 Resend → API Keys → 建立 API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# 2. 寄件者：需使用已驗證網域的信箱（Resend → Domains → Add Domain）
#    格式可以是純信箱或 "顯示名稱 <email>"
RESEND_FROM_EMAIL=Fantasy Report <report@yourdomain.com>

# 3. 多位收件者用逗號分隔
TO_EMAILS=recipient1@example.com,recipient2@example.com
