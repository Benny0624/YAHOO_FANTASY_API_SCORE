# ── Yahoo Fantasy API ──────────────────────────────────────────────
# 聯盟 ID，兩種格式皆可：
#   完整格式（推薦）：{game_key}.l.{league_number}，例如 423.l.230329
#   僅數字：230329（程式會自動補上當前賽季 game_key）
# 聯盟首頁 URL 可找到 league_number，game_key 可在 Yahoo Fantasy 開發者頁確認
YAHOO_LEAGUE_ID=your_league_id_here

# 執行 python local_auth.py 後取得的完整 JSON，貼成一行
YAHOO_OAUTH_JSON={"consumer_key":"your_key","consumer_secret":"your_secret","access_token":"...","refresh_token":"...","token_type":"bearer","guid":"...","token_time":1700000000.0,"expires_in":3600}

# 運動類型（mlb / nfl / nba / nhl）
YAHOO_SPORT=mlb

# ── LINE 推播（LINE Messaging API） ────────────────────────────────
# 1. LINE Developers Console (https://developers.line.biz/console/) 建立
#    一個 Messaging API Channel，取得 Channel access token（長效)
LINE_CHANNEL_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. 推播對象 ID：把 Bot 加入 LINE 群組後，群組裡任何動靜都會打到
#    /line-webhook，從 Render logs 複製印出的 groupId 貼在這裡
LINE_TARGET_ID=Cxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
