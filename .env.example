# ── Yahoo Fantasy API ──────────────────────────────────────────────
# 聯盟 ID（可在聯盟首頁 URL 找到，例如 423.l.12345 → 填 423.l.12345）
YAHOO_LEAGUE_ID=your_league_id_here

# 執行 python local_auth.py 後取得的完整 JSON，貼成一行
YAHOO_OAUTH_JSON={"consumer_key":"your_key","consumer_secret":"your_secret","access_token":"...","refresh_token":"...","token_type":"bearer","guid":"...","token_time":1700000000.0,"expires_in":3600}

# 運動類型（mlb / nfl / nba / nhl）
YAHOO_SPORT=mlb

# ── Outlook 寄信 ────────────────────────────────────────────────────
OUTLOOK_EMAIL=your_email@outlook.com

# 建議使用 App Password，非帳號密碼
# 設定路徑：Microsoft 帳號 → 安全性 → 應用程式密碼
OUTLOOK_PASSWORD=your_app_password_here

# 多位收件者用逗號分隔
OUTLOOK_TO_EMAILS=recipient1@example.com,recipient2@example.com
